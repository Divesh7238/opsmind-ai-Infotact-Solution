# Server Environment Variables
# Copy this to .env and adjust as needed

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (Required for full functionality)
# Use MongoDB Atlas or local MongoDB
MONGODB_URI=mongodb://localhost:27017/opsmind
# Alternative URI (fallback)
# MONGODB_URI_ALT=mongodb://localhost:27017/opsmind

# JWT Configuration (IMPORTANT: Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRE=7d

# Admin Configuration
ADMIN_EMAIL=admin@opsmind.ai
ADMIN_PASSWORD=admin123
ADMIN_INVITE_KEY=your-secure-invite-key

# AI Provider Configuration
# Choose either Gemini or OpenAI
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Client URL (for CORS in production)
CLIENT_URL=http://localhost:5173

